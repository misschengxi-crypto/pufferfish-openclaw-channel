{
  "name": "@qqvu/openclaw-channel",
  "version": "1.0.32",
  "description": "OpenClaw channel plugin for QQvu platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "QQvu Team",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
