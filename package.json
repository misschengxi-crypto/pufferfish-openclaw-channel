    "README.md",
    "LICENSE",
    "openclaw.plugin.json"
  ],
  "dependencies": {
    "crypto": "^1.0.1",
    "node-fetch": "^3.3.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/ws": "^8.5.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  }
}
